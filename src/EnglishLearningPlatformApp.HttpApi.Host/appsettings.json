{
  "App": {
    "SelfUrl": "https://localhost:44365",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.EnglishLearningPlatformApp.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": true,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "AuthServer": {
    "Authority": "https://localhost:44365",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "EnglishLearningPlatformApp_Swagger",
    "CertificatePassPhrase": ""
  },
  "StringEncryption": {
    "DefaultPassPhrase": ""
  }}
