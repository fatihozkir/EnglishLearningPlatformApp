{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": false
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "dev-app": {
      "projectType": "application",
      "root": "projects/dev-app",
      "sourceRoot": "projects/dev-app/src"
    },
    "reading": {
      "projectType": "library",
      "root": "projects/reading",
      "sourceRoot": "projects/reading/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/reading/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/reading/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/reading/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/reading/tsconfig.spec.json",
            "buildTarget": "projects/reading:build",
            "runner": "vitest"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/reading/**/*.ts",
              "projects/reading/**/*.html"
            ]
          }
        }
      }
    }
  }
}
