{
  "packages":[
    {
      "appRoutingModuleConfiguration":{
        "imports":[
          {
            "names":[
              "READING_ROUTES"
            ],
            "namespace": "@english-learning-platform-app/reading"
          } 
        ],
        "routes":[
          "{ path: 'reading', children: READING_ROUTES, canActivate: [authGuard] }"
        ]
      },
      "appModuleConfiguration":{
        "imports":[
          {
            "names":[
              "provideReading"
            ],
            "namespace": "@english-learning-platform-app/reading/config"
          }
        ],
        "providerNames":[
          "provideReading()"
        ]
      },
      "tsJsonPathRecordConfigurations":[
        {
          "name": "@english-learning-platform-app/reading",
          "paths": [
            "angular/projects/reading/src/public-api.ts"
          ]
        },
        {
          "name": "@english-learning-platform-app/reading/config",
          "paths": [
            "angular/projects/reading/config/src/public-api.ts"
          ]
        }
      ]
    }
  ]
}